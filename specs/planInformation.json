    "/medicare/plans": {
      "get": {
        "summary": "Medicare Plan List",
        "description": "Returns a list of Medicare plans",
        "parameters": [
          {
            "name": "lob",
            "in": "query",
            "description": "Type of plan",
            "required": false,
            "schema": {
              "type": "string",
              "default": "ALL",
              "enum": [
                "ALL",
                "MA",
                "MA_WITHOUT_SNP",
                "PDP"
              ]
            }
          },
          {
            "name": "fips",
            "in": "query",
            "required": true,
            "description": "Fips code of the area for which you are requesting plan information.",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "effectiveDate",
            "in": "query",
            "required": false,
            "description": "The date for which you are requesting plan information. Defaults to current date.  Dates should follow ISO format, 2017-04-19.",
            "schema": {
              "type": "string",
              "format": "date",
              "example": "2021-01-01"
            }
          }
        ],
        "tags": [
          "Medicare"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MedicarePlanListResponse"
                }
              }
            }
          },
          "default": {
            "description": "Error Response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Errors"
                }
              }
            }
          }
        }
      }
    },
