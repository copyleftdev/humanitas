{
    "openapi": "3.0.0",
    "info": {
        "version": "2.0.0",
        "title": "Small Groups Book of Business API"
    },
    "paths": {
        "/partners/{partner_id}/bob": {
            "get": {
                "description": "Return a partner's bob of business for all groups",
                "summary": "Get Partner's book of business",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/api-key"
                    },
                    {
                        "$ref": "#/components/parameters/partner_id"
                    },
                    {
                        "$ref": "#/components/parameters/group_details"
                    },
                    {
                        "$ref": "#/components/parameters/member_details"
                    },
                    {
                        "$ref": "#/components/parameters/as_of_date"
                    }
                ],
                "tags": [
                    "BOB"
                ],
                "responses": {
                    "200": {
                        "description": "Successful response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/PartnerBOBResponse"
                                }
                            },
                            "application/pdf": {
                                "schema": {
                                    "$ref": "#/components/schemas/PartnerBOBResponse"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "Error Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Errors"
                                }
                            },
                            "application/pdf": {
                                "schema": {
                                    "$ref": "#/components/schemas/Errors"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/partners/{partner_id}/bob/{group_id}": {
            "get": {
                "description": "Return a group's book of business",
                "summary": "Get Book of Business",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/api-key"
                    },
                    {
                        "$ref": "#/components/parameters/group_id"
                    },
                    {
                        "$ref": "#/components/parameters/partner_id"
                    },
                    {
                        "$ref": "#/components/parameters/group_details"
                    },
                    {
                        "$ref": "#/components/parameters/member_details"
                    },
                    {
                        "$ref": "#/components/parameters/as_of_date"
                    }
                ],
                "tags": [
                    "BOB"
                ],
                "responses": {
                    "200": {
                        "description": "Successful response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/GroupBOBResponse"
                                }
                            },
                            "application/pdf": {
                                "schema": {
                                    "$ref": "#/components/schemas/GroupBOBResponse"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "Error Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Errors"
                                }
                            },
                            "application/pdf": {
                                "schema": {
                                    "$ref": "#/components/schemas/Errors"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://api.example.com/v2/small-groups"
        }
    ],
    "components": {
        "parameters": {
            "api-key": {
                "name": "x-humana-api-key",
                "in": "header",
                "description": "API Key",
                "required": true,
                "schema": {
                    "type": "string"
                }
            },
            "group_id": {
                "name": "group_id",
                "in": "path",
                "required": true,
                "description": "The group number that uniquely identifies the group on which operations should be performed.",
                "schema": {
                    "type": "string"
                }
            },
            "accept": {
                "name": "accept",
                "in": "header",
                "required": false,
                "schema": {
                    "type": "string",
                    "enum": [
                        "application/json"
                    ]
                }
            },
            "as_of_date": {
                "name": "as_of_date",
                "in": "query",
                "required": false,
                "description": "Date filter to look up group information.  Defaults to today's date.  Format is YYYY-MM-DD",
                "schema": {
                    "type": "string",
                    "format": "date"
                }
            },
            "member_details": {
                "name": "member_details",
                "in": "query",
                "required": false,
                "description": "Field determines whether or not member data will be retrieved.  Defaults to true.",
                "schema": {
                    "type": "boolean",
                    "default": true
                }
            },
            "group_details": {
                "name": "group_details",
                "in": "query",
                "required": false,
                "description": "Field determines wheter or not group data will be retrieved. Defaults to true.",
                "schema": {
                    "type": "boolean",
                    "default": true
                }
            },
            "partner_id": {
                "name": "partner_id",
                "in": "path",
                "required": true,
                "description": "The partner id for a specific partner.",
                "schema": {
                    "type": "string"
                }
            }
        },
