                    "coverageTerminationDate": {
                        "type": "string",
                        "format": "date"
                    },
                    "accretionCode": {
                        "type": "string"
                    },
                    "solarGroupId": {
                        "type": "string"
                    },
                    "member": {
                        "$ref": "#/components/schemas/Member"
                    },
                    "agent": {
                        "$ref": "#/components/schemas/Agent"
                    },
                    "product": {
                        "$ref": "#/components/schemas/Product"
                    }
                }
            },
            "ReportResponse": {
                "properties": {
                    "records": {
                        "type": "array",
                        "items": {
                            "$ref": "#/components/schemas/Report"
                        }
                    },
                    "total": {
                        "type": "number",
                        "example": 500
                    }
                }
            },
            "Error": {
                "properties": {
                    "code": {
                        "description": "An application-specific error code, expressed as a string value.",
                        "example": "ENR500-000",
                        "type": "string"
                    },
                    "detail": {
                        "description": "A human-readable explanation specific to this occurrence of the problem. Like title, this fieldÃƒÆ’Ã†â€™Ãƒâ€šÃ‚Â¢ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¡Ãƒâ€šÃ‚Â¬ÃƒÆ’Ã‚Â¢ÃƒÂ¢Ã¢â€šÂ¬Ã…Â¾Ãƒâ€šÃ‚Â¢s value can be localized.",
                        "example": "Enter a value in the First Name field. If you do not know the first name then enter a space. The First Name field cannot be submitted with a null.",
                        "type": "string"
                    }
                },
                "required": [
                    "code",
                    "detail"
                ],
                "type": "object"
            },
            "Errors": {
                "type": "object",
                "properties": {
                    "errors": {
                        "items": {
                            "$ref": "#/components/schemas/Error"
