{
    "openapi": "3.0.0",
    "info": {
        "version": "2.0.0",
        "title": "Enrollment Reporting V1",
        "description": "Reporting API for enrollment data."
    },
    "paths": {
        "/medicare/bam": {
            "post": {
                "summary": "BAM Report",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/api-key"
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/BAMRequest"
                            }
                        }
                    },
                    "required": true
                },
                "tags": [
                    "Medicare"
                ],
                "responses": {
                    "200": {
                        "description": "Successful response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ReportResponse"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "Error Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Errors"
                                }
                            }
                        }
                    }
                }
            }
        },
        "/medicare/aped": {
            "post": {
                "summary": "APED Report",
                "parameters": [
                    {
                        "$ref": "#/components/parameters/api-key"
                    }
                ],
                "requestBody": {
                    "content": {
                        "application/json": {
                            "schema": {
                                "$ref": "#/components/schemas/APEDRequest"
                            }
                        }
                    },
                    "required": true
                },
                "tags": [
                    "Medicare"
                ],
                "responses": {
                    "200": {
                        "description": "Successful response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/ReportResponse"
                                }
                            }
                        }
                    },
                    "default": {
                        "description": "Error Response",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/Errors"
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "servers": [
        {
            "url": "https://api.example.com/v1/enrollment/reporting"
        }
    ],
    "components": {
        "parameters": {
            "api-key": {
                "name": "x-humana-api-key",
                "in": "header",
                "description": "API Key",
                "required": true,
                "schema": {
                    "type": "string"
                }
            }
        },
        "schemas": {
            "Sort": {
                "properties": {
                    "by": {
                        "type": "string"
                    },
                    "order": {
                        "type": "string",
                        "enum": [
                            "asc",
                            "desc"
                        ]
                    }
                }
            },
            "BAMRequest": {
                "properties": {
                    "partnerId": {
                        "type": "string"
                    },
                    "writingAgentSAN": {
                        "type": "string"
                    },
                    "medicareId": {
                        "type": "string"
                    },
                    "coverageStartDate": {
                        "type": "string",
                        "format": "date"
                    },
                    "coverageEndDate": {
                        "type": "string",
                        "format": "date"
                    },
                    "coverageTerminationStartDate": {
                        "type": "string",
                        "format": "date"
                    },
                    "coverageTerminationEndDate": {
                        "type": "string",
                        "format": "date"
                    },
                    "signatureStartDate": {
                        "type": "string",
                        "format": "date"
                    },
                    "signatureEndDate": {
                        "type": "string",
                        "format": "date"
                    },
                    "status": {
                        "type": "array",
                        "enum": [
                            "pended",
                            "inProgress",
                            "approved",
                            "cancelled",
                            "submitted"
                        ],
                        "items": {
                            "type": "string"
                        }
                    },
                    "planType": {
                        "type": "string",
                        "enum": [
                            "IDV",
                            "MA",
                            "MES",
                            "OSB",
                            "PDP"
                        ]
                    },
                    "sort": {
                        "$ref": "#/components/schemas/Sort"
                    },
                    "offset": {
                        "type": "number",
                        "default": 0
                    },
                    "limit": {
                        "type": "number",
                        "default": 100
                    }
                },
                "required": [
                    "partnerId"
                ]
            },
            "APEDRequest": {
                "properties": {
                    "partnerId": {
                        "type": "string"
                    },
                    "writingAgentSAN": {
                        "type": "string"
                    },
                    "medicareId": {
                        "type": "string"
                    },
                    "coverageStartDate": {
                        "type": "string",
                        "format": "date"
                    },
                    "coverageEndDate": {
                        "type": "string",
                        "format": "date"
                    },
                    "coverageTerminationStartDate": {
                        "type": "string",
                        "format": "date"
                    },
                    "coverageTerminationEndDate": {
