                    },
                    "planType": {
                        "type": "string",
                        "enum": [
                            "IDV",
                            "MA",
                            "MES",
                            "OSB",
                            "PDP"
                        ]
                    },
                    "sort": {
                        "$ref": "#/components/schemas/Sort"
                    },
                    "offset": {
                        "type": "number",
                        "default": 0
