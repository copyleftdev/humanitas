                "properties": {
                    "firstName": {
                        "type": "string"
                    },
                    "lastName": {
                        "type": "string"
                    },
                    "npn": {
                        "type": "string"
                    },
                    "san": {
                        "type": "string"
                    }
                }
            },
            "Report": {
                "properties": {
                    "applicationTypeCode": {
                        "type": "string"
                    },
                    "partnerApplicationId": {
                        "type": "string"
                    },
                    "enrollmentId": {
                        "type": "string"
                    },
                    "policyId": {
                        "type": "string"
                    },
                    "signatureDate": {
                        "type": "string",
                        "format": "date"
                    },
                    "marketReceiptDate": {
                        "type": "string",
                        "format": "date"
                    },
                    "coverageEffectiveDate": {
                        "type": "string",
