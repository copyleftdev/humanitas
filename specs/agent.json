{
  "swagger": "2.0",
  "info": {
    "version": "2.0.0",
    "title": "Agents API"
  },
  "host": "api.example.com",
  "schemes": [
    "https"
  ],
  "basePath": "/v1/agents",
  "produces": [
    "application/json"
  ],
  "parameters": {
    "api-key": {
      "name": "x-humana-api-key",
      "in": "header",
      "description": "API Key",
      "required": true,
      "type": "string"
    },
    "san": {
      "name": "san",
      "in": "path",
      "required": true,
      "type": "string"
    }
  },
  "paths": {
    "/{san}": {
      "get": {
        "description": "Get Agent demographic details",
        "summary": "Get Agent by SAN",
        "parameters": [
          {
            "$ref": "#/parameters/api-key"
          },
          {
            "$ref": "#/parameters/san"
          }
        ],
        "tags": [
          "Agent"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "schema": {
              "$ref": "#/definitions/Agent"
            }
          },
          "default": {
            "description": "Error Response",
            "schema": {
              "$ref": "#/definitions/Errors"
            }
          }
        }
      }
    },
    "/{san}/plans": {
      "get": {
        "description": "Get list of plans an Agent is allowed to sell for AOA",
        "summary": "Get AOA Plans",
        "parameters": [
          {
            "$ref": "#/parameters/api-key"
          },
          {
            "$ref": "#/parameters/san"
          },
          {
            "name": "fips",
            "type": "string",
            "in": "query",
            "required": true
          },
          {
            "name": "state",
            "type": "string",
            "in": "query",
            "required": true
          },
          {
            "name": "as_of_date",
            "type": "string",
            "in": "query",
            "required": true,
            "description": "ISO Format Date, defaults to today's date."
          }
        ],
        "tags": [
          "Plans"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "schema": {
              "$ref": "#/definitions/PlanResponse"
            }
          },
          "default": {
            "description": "Error Response",
            "schema": {
              "$ref": "#/definitions/Errors"
            }
          }
        }
      }
    },
    "/{san}/all-plans": {
      "get": {
        "description": "Get all plans an Agent is allowed to sell",
        "summary": "Get All Plans",
        "parameters": [
          {
            "$ref": "#/parameters/api-key"
          },
          {
            "$ref": "#/parameters/san"
          },
          {
            "name": "fips",
            "type": "string",
            "in": "query",
            "required": true
          },
          {
            "name": "state",
            "type": "string",
            "in": "query",
            "required": true
          },
          {
            "name": "as_of_date",
            "type": "string",
            "in": "query",
            "required": true,
            "description": "ISO Format Date, defaults to today's date."
          },
          {
            "name": "careplus",
            "type": "boolean",
            "in": "query",
            "required": false,
            "default": true,
            "description": "Include careplus plans in the response"
          },
          {
            "name": "med_supp",
            "type": "boolean",
            "in": "query",
            "required": false,
            "default": true,
            "description": "Include med supp plans in the response"
          }
        ],
        "tags": [
          "Plans"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "schema": {
              "$ref": "#/definitions/AllPlanResponse"
            }
          },
          "default": {
            "description": "Error Response",
            "schema": {
              "$ref": "#/definitions/Errors"
            }
          }
        }
      }
    },
    "/{san}/certifications": {
      "get": {
        "description": "Get list of certifications for an Agent",
        "summary": "Get Agent Certifications",
        "parameters": [
          {
            "$ref": "#/parameters/api-key"
          },
          {
            "$ref": "#/parameters/san"
          }
        ],
        "tags": [
          "Certifications"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "schema": {
              "$ref": "#/definitions/CertificationResponse"
            }
          },
          "default": {
            "description": "Error Response",
            "schema": {
              "$ref": "#/definitions/Errors"
            }
          }
        }
      }
    },
    "/{san}/licenses": {
      "get": {
        "description": "Get list of licenses for an Agent",
        "summary": "Get Agent Licenses",
        "parameters": [
          {
            "$ref": "#/parameters/api-key"
          },
          {
            "$ref": "#/parameters/san"
          }
        ],
        "tags": [
          "Licenses"
        ],
        "responses": {
          "200": {
            "description": "Successful response",
            "schema": {
              "$ref": "#/definitions/LicenseResponse"
            }
          },
          "default": {
            "description": "Error Response",
            "schema": {
              "$ref": "#/definitions/Errors"
            }
          }
        }
      }
    }
  },
